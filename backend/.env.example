# ── Database ─────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=hotel_menu

# ── JWT ───────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string_at_least_64_chars
JWT_EXPIRES_IN=8h

# ── Server ────────────────────────────────
PORT=4000
NODE_ENV=development

# ── Frontend URL (for CORS) ───────────────
CLIENT_URL=http://localhost:4000
